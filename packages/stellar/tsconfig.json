{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "node",
    "composite": false,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@ancore/types": ["../types/dist"],
      "@ancore/types/*": ["../types/dist/*"]
    }
  },
  "references": [{ "path": "../types" }],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
